@page
@model Mango.Services.Identity.Pages.Account.Login.Index

<div class="login-page">
    <div class="lead">
        <h1>Login</h1>
        <p>Choose how to login</p>
    </div>

    <partial name="_ValidationSummary" />

    <div class="row">

    @if (Model.View.EnableLocalLogin)
    {
        <div class="col-md-4">
            <div class="card shadow-sm h-100">
                <div class="card-header text-center">
                    <h4>🔐 Local Account</h4>
                </div>

                <div class="card-body">
                    <form asp-page="/Account/Login/Index">
                        <input type="hidden" asp-for="Input.ReturnUrl" />

                        <div class="form-group mb-3">
                            <label asp-for="Input.Username"></label>
                            <input class="form-control" asp-for="Input.Username" autofocus>
                        </div>

                        <div class="form-group mb-3">
                            <label asp-for="Input.Password"></label>
                            <input type="password" class="form-control" asp-for="Input.Password">
                        </div>

                        @if (Model.View.AllowRememberLogin)
                        {
                            <div class="form-check mb-3">
                                <input class="form-check-input" asp-for="Input.RememberLogin">
                                <label class="form-check-label" asp-for="Input.RememberLogin">
                                    Remember me
                                </label>
                            </div>
                        }

                        <button class="btn btn-primary w-100" name="Input.Button" value="login">
                            Login
                        </button>
                    </form>
                </div>
            </div>
        </div>
    }

    @if (Model.View.VisibleExternalProviders.Any())
    {
        <div class="col-md-4">
            <div class="card shadow-sm h-100">
                <div class="card-header text-center">
                    <h4>🌐 External Account</h4>
                </div>

                <div class="card-body text-center">
                    @foreach (var provider in Model.View.VisibleExternalProviders)
                    {
                        <a class="btn btn-outline-secondary w-100 mb-2"
                           asp-page="/ExternalLogin/Challenge"
                           asp-route-scheme="@provider.AuthenticationScheme"
                           asp-route-returnUrl="@Model.Input.ReturnUrl">
                            Sign in with @provider.DisplayName
                        </a>
                    }
                </div>
            </div>
        </div>
    }

    <div class="col-md-4">
        <div class="card shadow-sm h-100 border-success">
            <div class="card-header text-center bg-success text-white">
                <h4>➕ Create Account</h4>
            </div>

            <div class="card-body text-center">
                <p class="text-muted">
                    Don’t have an account yet?
                </p>

                <a class="btn btn-success w-100"
                   asp-page="/Account/Create/Index"
                   asp-route-returnUrl="@Model.Input.ReturnUrl">
                    Create New Account
                </a>
            </div>
        </div>
    </div>

</div>
</div>
