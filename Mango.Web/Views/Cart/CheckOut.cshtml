@model Mango.Web.Models.CartDTO

<form method="post">
    <div>
        <span style="font-size:25px;" class="text-warning">Enter details and place order :</span>
        <br />
    </div>

    <div class="border mt-2">
        <div class="container row">
            <div class="col-7">
                <div class="row">
                    <div class="col-12">
                        <label asp-for="CartHeader.FirstName" class="col-form-label"></label>
                        <input asp-for="CartHeader.FirstName" class="form-control" />
                        <span asp-validation-for="CartHeader.FirstName" class="text-danger"></span>
                    </div>

                    <div class="col-12">
                        <label asp-for="CartHeader.LastName" class="col-form-label"></label>
                        <input asp-for="CartHeader.LastName" class="form-control" />
                        <span asp-validation-for="CartHeader.LastName" class="text-danger"></span>
                    </div>

                    <div class="col-12">
                        <label asp-for="CartHeader.Email" class="col-form-label"></label>
                        <input asp-for="CartHeader.Email" class="form-control" />
                        <span asp-validation-for="CartHeader.Email" class="text-danger"></span>
                    </div>

                    <div class="col-12">
                        <label asp-for="CartHeader.Phone" class="col-form-label"></label>
                        <input asp-for="CartHeader.Phone" class="form-control" />
                        <span asp-validation-for="CartHeader.Phone" class="text-danger"></span>
                    </div>

                    <div class="col-12">
                        <label asp-for="CartHeader.PickupDateTime" class="col-form-label"></label>
                        <input asp-for="CartHeader.PickupDateTime" class="form-control" type="datetime-local" />
                        <span asp-validation-for="CartHeader.PickupDateTime" class="text-danger"></span>
                    </div>

                    <div class="col-12">
                        <label asp-for="CartHeader.CardNumber" class="col-form-label"></label>
                        <input asp-for="CartHeader.CardNumber" class="form-control" />
                        <span asp-validation-for="CartHeader.CardNumber" class="text-danger"></span>
                    </div>

                    <div class="col-12">
                        <label asp-for="CartHeader.CVV" class="col-form-label"></label>
                        <input asp-for="CartHeader.CVV" class="form-control" />
                        <span asp-validation-for="CartHeader.CVV" class="text-danger"></span>
                    </div>

                    <div class="col-12 pb-4">
                        <label asp-for="CartHeader.ExpiryMonthYear" class="col-form-label"></label>
                        <input asp-for="CartHeader.ExpiryMonthYear" placeholder="MMYY" class="form-control" />
                        <span asp-validation-for="CartHeader.ExpiryMonthYear" class="text-danger"></span>
                    </div>
                </div>
            </div>

            <div class="col-5">
                <div class="card mt-4">
                    <div class="card-body">
                        <div class="d-none d-lg-block">
                            <div class="row text-danger">
                                <div class="col-6">
                                    Product Details
                                </div>
                                <div class="col-3">
                                    Price
                                </div>
                                <div class="col-3">
                                    Count
                                </div>
                            </div>
                        </div>

                        <hr />

                        @foreach (var item in Model.CartDetails)
                        {
                            <div class="row h-100">
                                <div class="col-6">
                                    <span style="font-size:20px">@item.ProductName</span>
                                </div>

                                <div class="col-3" style="font-size:11px;">
                                    <span style="font-size:17px;">$@item.Price</span>
                                </div>

                                <div class="col-3" style="font-size:11px;">
                                    <span style="font-size:17px;">@item.Count</span>
                                </div>
                            </div>

                            <hr />
                        }

                        <div class="row">
                            <div class="col-12 text-end pe-4 text-danger">
                                Order Total : $@Model.CartHeader.OrderTotal <br />

                            </div>
                            <div class="col-12 text-end pe-4 text-success">
                                @if (Model.CartHeader.Discount > 0)
                                {
                                        <span>Discount : $@Model.CartHeader.Discount</span>

                                        <br />
                                }

                                @if (!string.IsNullOrWhiteSpace(Model.CartHeader.CouponCode))
                                {
                                    <span>Coupon : @Model.CartHeader.CouponCode</span>
                                }
                            </div>
                            
                        </div>
                    </div>

                    <div class="card-footer">
                        <div class="row">
                            <div class="col-12">
                                <button type="submit" class="btn btn-success form-control">
                                    <span>Place Order</span>
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</form>