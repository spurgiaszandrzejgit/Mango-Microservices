@model Mango.Web.Models.CartDTO

@{
    ViewData["Title"] = "Shopping Cart";
    var subtotal = Model?.CartDetails?.Sum(x => x.Price * x.Count) ?? 0;
    var orderTotal = Model?.CartHeader?.OrderTotal ?? subtotal;
}

<div class="container mt-4">
    <div class="card border-0 shadow-sm">
        <div class="card-header bg-dark text-white">
            <h3 class="mb-0">Shopping Cart</h3>
        </div>

        <div class="card-body">

            @if (Model == null || Model.CartDetails == null || !Model.CartDetails.Any())
            {
                <div class="alert alert-info">
                    Your cart is empty.
                </div>

                <a asp-controller="Home" asp-action="Index" class="btn btn-outline-primary">
                    Back to Main page
                </a>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-bordered align-middle">
                        <thead class="table-light">
                            <tr>
                                <th>Product</th>
                                <th style="width:120px;">Price</th>
                                <th style="width:180px;">Quantity</th>
                                <th style="width:140px;">Subtotal</th>
                                <th style="width:140px;">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model.CartDetails)
                            {
                                <tr>
                                    <td>
                                        <div class="d-flex align-items-center gap-3">
                                            @if (!string.IsNullOrWhiteSpace(item.ImageUrl))
                                            {
                                                <img src="@item.ImageUrl"
                                                     alt="@item.ProductName"
                                                     style="width:70px;height:70px;object-fit:cover;"
                                                     class="rounded border" />
                                            }
                                            <div>
                                                <div class="fw-bold">@item.ProductName</div>
                                                <div class="text-muted small">@item.CategoryName</div>
                                            </div>
                                        </div>
                                    </td>

                                    <td>@item.Price.ToString("C")</td>

                                    <td>
                                        <form asp-controller="Cart" asp-action="UpdateQuantity" method="post" class="d-flex gap-2">
                                            <input type="hidden" name="productId" value="@item.ProductId" />
                                            <input type="number"
                                                   name="count"
                                                   value="@item.Count"
                                                   min="1"
                                                   class="form-control" />
                                            <button type="submit" class="btn btn-warning btn-sm">
                                                Update
                                            </button>
                                        </form>
                                    </td>

                                    <td>@((item.Price * item.Count).ToString("C"))</td>

                                    <td>
                                        <form asp-controller="Cart" asp-action="Remove" method="post">
                                            <input type="hidden" name="productId" value="@item.ProductId" />
                                            <button type="submit" class="btn btn-danger btn-sm">
                                                Remove
                                            </button>
                                        </form>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                <div class="row mt-4">
                    <div class="col-md-6">
                        <form asp-controller="Cart" asp-action="ApplyCoupon" method="post" class="card card-body">
                            <label class="form-label fw-semibold">Promo Code</label>
                            <div class="input-group">
                                <input type="text"
                                       name="couponCode"
                                       value="@Model.CartHeader?.CouponCode"
                                       class="form-control"
                                       placeholder="Enter promo code" />
                                <button type="submit" class="btn btn-primary">
                                    Apply
                                </button>
                            </div>
                        </form>
                    </div>

                    <div class="col-md-6">
                        <div class="card card-body">
                            <div class="d-flex justify-content-between mb-2">
                                <span>Calculated subtotal:</span>
                                <span>@subtotal.ToString("C")</span>
                            </div>

                            <hr />

                            <div class="d-flex justify-content-between fw-bold fs-5">
                                <span>Order total:</span>
                                <span>@orderTotal.ToString("C")</span>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="d-flex justify-content-between mt-4">
                    <a asp-controller="Home" asp-action="Index" class="btn btn-outline-secondary">
                        Back to Main page
                    </a>

                    <form asp-controller="Cart" asp-action="Checkout" method="post">
                        <button type="submit" class="btn btn-success">
                            Order Now
                        </button>
                    </form>
                </div>
            }
        </div>
    </div>
</div>