@{
    ViewData["Title"] = "Confirmation";
}

<div class="container pt-5">
    <div class="card border-0 shadow-lg bg-dark text-light">
        <div class="card-body text-center p-5">
            <h1 class="text-info mb-4">Congratulations! You are one step closer to amazing food.</h1>
            <p class="fs-5 mb-4">We have received your order and your payment will be processed soon.</p>
            <img src="~/images/order.PNG" class="img-fluid rounded" style="max-width: 700px;" alt="Order Confirmation" />
        </div>
    </div>
</div>