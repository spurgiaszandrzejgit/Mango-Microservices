@model Mango.Web.Models.ProductDTO

<form asp-action="AddToCart" method="post">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
    <input type="hidden" asp-for="ProductId" />

    <div class="container mt-5">
        <div class="card shadow-lg border-0">

            <div class="card-header bg-dark text-light d-flex justify-content-between align-items-center">
                <h2 class="mb-0">@Model.Name</h2>
                <h3 class="text-warning mb-0">@Model.Price.ToString("c")</h3>
            </div>

            <div class="card-body">
                <div class="row">

                    <div class="col-12 col-lg-4 text-center mb-3 mb-lg-0">
                        <img src="@Model.ImageUrl"
                             class="img-fluid rounded shadow-sm"
                             style="max-height:350px; object-fit:cover;" />
                    </div>

                    <div class="col-12 col-lg-8">

                        <span class="badge bg-secondary mb-3">@Model.CategoryName</span>

                        <p class="text-muted fs-5" style="white-space:pre-line;">
                            @Model.Description
                        </p>

                        <div class="row mt-4">
                            <div class="col-4">
                                <label asp-for="Count" class="form-label fw-bold"></label>
                                <input asp-for="Count" type="number" class="form-control" min="1" max="100" />
                                <span asp-validation-for="Count" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="row mt-4">
                            <div class="col-12 col-md-6 mb-2">
                                <a asp-action="Index" class="btn btn-outline-secondary w-100 btn-lg">
                                    Back to List
                                </a>
                            </div>

                            <div class="col-12 col-md-6">
                                <button type="submit" class="btn btn-success w-100 btn-lg">
                                    Add to Cart
                                </button>
                            </div>
                        </div>

                    </div>
                </div>
            </div>

        </div>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}