@model IEnumerable<Mango.Web.Models.ProductDTO>

<br />
<br />
<div class="container p-4 border">
    <div class="row pb-2">
        <div class="col">
            <h1 class="text-primary">Products List</h1>
        </div>
        <div class="col text-end pt-1">
            <a asp-action="ProductCreate" class="btn btn-outline-primary">
                <i class="bi bi-plus"></i> Create New Product
            </a>
        </div>
    </div>
    <table class="table">
        <thead class="border-bottom">
            <tr>
                <th>Name</th>
                <th>Category Name</th>
                <th class="text-end">Price</th>
                <th class="text-end">Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr class="align-middle">
                    <td class="fw-semibold">
                        @item.Name
                    </td>

                    <td>
                        <span class="badge bg-secondary">
                            @item.CategoryName
                        </span>
                    </td>

                    <td class="text-end">
                        @item.Price.ToString("c")
                    </td>

                    <td class="text-end">
                        <div class="d-inline-flex gap-2">
                            <a asp-action="ProductEdit"
                               asp-route-productId="@item.ProductId"
                               class="btn btn-sm btn-outline-success">
                                <i class="bi bi-pencil-square me-1"></i> Edit
                            </a>

                            <a asp-action="ProductDelete"
                               asp-route-productId="@item.ProductId"
                               class="btn btn-sm btn-outline-danger">
                                <i class="bi bi-trash me-1"></i> Delete
                            </a>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>

</div>