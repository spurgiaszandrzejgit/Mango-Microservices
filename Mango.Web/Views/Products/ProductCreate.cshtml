@model Mango.Web.Models.ProductVM

<form asp-action="ProductCreate" method="post" enctype="multipart/form-data">
    <br />
    <div class="container border p-3">
        <h1 class="text-info">Create Product</h1>
        <hr />

        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

        <div class="row g-3">
            <div class="col-2">
                <label asp-for="Name" class="form-label pt-2" style="font-size:20px;"></label>
            </div>
            <div class="col-10">
                <input asp-for="Name" class="form-control" />
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>

            <div class="col-2">
                <label asp-for="CategoryName" class="form-label pt-2" style="font-size:20px;"></label>
            </div>
            <div class="col-10">
                <input asp-for="CategoryName" class="form-control" />
                <span asp-validation-for="CategoryName" class="text-danger"></span>
            </div>

            <div class="col-2">
                <label asp-for="Description" class="form-label pt-2" style="font-size:20px;"></label>
            </div>
            <div class="col-10">
                <textarea asp-for="Description" class="form-control" rows="5"></textarea>
                <span asp-validation-for="Description" class="text-danger"></span>
            </div>

            <div class="col-2">
                <label asp-for="Price" class="form-label pt-2" style="font-size:20px;"></label>
            </div>
            <div class="col-10">
                <input asp-for="Price" class="form-control" type="number" step="0.01" />
                <span asp-validation-for="Price" class="text-danger"></span>
            </div>

            <div class="col-2">
                <label asp-for="ImageFile" class="form-label pt-2" style="font-size:20px;">Image</label>
            </div>
            <div class="col-10">
                <input asp-for="ImageFile" class="form-control" type="file" accept="image/*" />
                <span asp-validation-for="ImageFile" class="text-danger"></span>
            </div>

            <div class="col-5 offset-2">
                <a asp-action="ProductIndex" class="btn btn-outline-secondary form-control">
                    Back to List
                </a>
            </div>
            <div class="col-5">
                <button type="submit" class="btn btn-success form-control">
                    Create
                </button>
            </div>
        </div>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}