@model Mango.Web.Models.ProductVM

<form asp-controller="Products"
      asp-action="ProductDelete"
      method="post">

    @Html.AntiForgeryToken()
    <input asp-for="ProductId" type="hidden" />

    <br />
    <div class="container border p-3">
        <h1 class="text-danger">Delete Product</h1>
        <hr />

        <div class="row g-3">
            <div class="col-12 col-lg-8">
                <div class="mb-2">
                    <span class="fw-semibold">Name:</span> @Model.Name
                </div>

                <div class="mb-2">
                    <span class="fw-semibold">Category:</span> @Model.CategoryName
                </div>

                <div class="mb-2">
                    <span class="fw-semibold">Price:</span> @Model.Price.ToString("c")
                </div>

                <div class="alert alert-warning mt-3">
                    Are you sure you want to delete this product?
                </div>

                <div class="d-flex gap-2">
                    <a asp-controller="Products"
                       asp-action="ProductsIndex"
                       class="btn btn-outline-secondary">
                        Cancel
                    </a>

                    <button type="submit" class="btn btn-danger">
                        <i class="bi bi-trash me-1"></i> Delete
                    </button>
                </div>
            </div>

            <div class="col-12 col-lg-4">
                <div class="border rounded p-3">
                    <div class="fw-semibold mb-2">Image</div>

                    @if (!string.IsNullOrWhiteSpace(Model.ExistingImageUrl))
                    {
                        <img src="@Model.ExistingImageUrl"
                             class="img-fluid rounded"
                             style="max-height: 220px; object-fit: contain;" />
                    }
                    else
                    {
                        <div class="text-muted">No image</div>
                    }
                </div>
            </div>
        </div>
    </div>
</form>