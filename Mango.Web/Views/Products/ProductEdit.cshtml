@model Mango.Web.Models.ProductVM

<form asp-controller="Products" asp-action="ProductEdit" method="post" enctype="multipart/form-data">
    @Html.AntiForgeryToken()

    <br />
    <div class="container border p-3">
        <div class="d-flex justify-content-between align-items-center">
            <h1 class="text-primary mb-0">Edit Product</h1>
            <a asp-controller="Products" asp-action="ProductsIndex" class="btn btn-outline-secondary">
                <i class="bi bi-arrow-left me-1"></i> Back to List
            </a>
        </div>

        <hr />

        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

        <input asp-for="ProductId" type="hidden" />
        <input asp-for="ExistingImageUrl" type="hidden" />

        <div class="row g-3">
            <div class="col-12 col-lg-8">
                <div class="row g-3">
                    <div class="col-2">
                        <label asp-for="Name" class="form-label pt-2" style="font-size:20px;"></label>
                    </div>
                    <div class="col-10">
                        <input asp-for="Name" class="form-control" />
                        <span asp-validation-for="Name" class="text-danger"></span>
                    </div>

                    <div class="col-2">
                        <label asp-for="CategoryName" class="form-label pt-2" style="font-size:20px;"></label>
                    </div>
                    <div class="col-10">
                        <input asp-for="CategoryName" class="form-control" />
                        <span asp-validation-for="CategoryName" class="text-danger"></span>
                    </div>

                    <div class="col-2">
                        <label asp-for="Description" class="form-label pt-2" style="font-size:20px;"></label>
                    </div>
                    <div class="col-10">
                        <textarea asp-for="Description" class="form-control" rows="5"></textarea>
                        <span asp-validation-for="Description" class="text-danger"></span>
                    </div>

                    <div class="col-2">
                        <label asp-for="Price" class="form-label pt-2" style="font-size:20px;"></label>
                    </div>
                    <div class="col-10">
                        <input asp-for="Price" class="form-control" type="number" step="0.01" />
                        <span asp-validation-for="Price" class="text-danger"></span>
                    </div>

                    <div class="col-2">
                        <label asp-for="ImageFile" class="form-label pt-2" style="font-size:20px;">New Image</label>
                    </div>
                    <div class="col-10">
                        <input asp-for="ImageFile" class="form-control" type="file" accept="image/*" />
                        <div class="form-text">
                            If you don’t choose a file, the current image will stay.
                        </div>
                        <span asp-validation-for="ImageFile" class="text-danger"></span>
                    </div>

                    <div class="col-12">
                        <button type="submit" class="btn btn-primary w-100">
                            <i class="bi bi-check2-circle me-1"></i> Save Changes
                        </button>
                    </div>
                </div>
            </div>

            <div class="col-12 col-lg-4">
                <div class="border rounded p-3 h-100">
                    <div class="d-flex align-items-center mb-2">
                        <i class="bi bi-image me-2"></i>
                        <span class="fw-semibold">Current Image</span>
                    </div>

                    @if (!string.IsNullOrWhiteSpace(Model.ExistingImageUrl))
                    {
                        <img src="@Model.ExistingImageUrl"
                             class="img-fluid rounded shadow-sm"
                             style="max-height: 260px; object-fit: contain;"
                             alt="Product image" />
                    }
                    else
                    {
                        <div class="text-muted">
                            No image uploaded.
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
